# ===========================================================
# Переменные окружения для сайта КБ Парус
# Скопируйте этот файл в .env.local и заполните значения
# ===========================================================

# --- Telegram-бот для уведомлений менеджеров (РЕКОМЕНДУЕТСЯ) ---
# Получить токен у @BotFather → /newbot → следуйте инструкциям
# TELEGRAM_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=

# ID группы или личного чата, куда бот будет писать заявки
# Группа: создайте группу, добавьте бота как администратора, отправьте /start
# Чтобы узнать chat_id: добавьте @userinfobot или @getidsbot в группу
# Для группы chat_id обычно отрицательный (например, -1001234567890)
# TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_CHAT_ID=

# --- Bitrix24 webhook (опционально) ---
# Создаётся в Bitrix24: Приложения → Webhooks → Входящий webhook
# Разрешите права crm.deal.add, crm.lead.add
# Формат: https://YOUR.bitrix24.ru/rest/USER_ID/TOKEN/
BITRIX24_WEBHOOK_URL=

# Приоритет каналов:
# 1. Если установлены ТОЛЬКО TELEGRAM_* — заявки только в Telegram
# 2. Если установлены ТОЛЬКО BITRIX24_* — заявки только в CRM
# 3. Если установлены ОБА — заявки идут параллельно в Telegram И CRM (рекомендуется)
# 4. Если ничего не установлено — mock-режим, заявки просто логируются
