{
  "name": "kbparus-metal-storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/cms/check.mjs && node scripts/cms/safe-generate-importmap.mjs && node scripts/cms/push-schema.mjs && node scripts/cms/check.mjs && next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "cms:check": "node scripts/cms/check.mjs",
    "cms:generate-importmap": "node scripts/cms/safe-generate-importmap.mjs",
    "cms:push-schema": "node scripts/cms/push-schema.mjs",
    "cms:validate-deployment": "node scripts/cms/validate-deployment.mjs",
    "cms:admin-smoke": "node scripts/cms/admin-smoke.mjs",
    "cms:seed-catalog": "tsx scripts/cms/seed-catalog-remote.ts",
    "cms:seed-home-content": "tsx scripts/cms/seed-home-content-remote.ts",
    "cms:seed-media": "tsx scripts/cms/seed-media-remote.ts",
    "cms:seed-site-navigation": "tsx scripts/cms/seed-site-navigation-remote.ts",
    "cms:seed-catalog:local": "tsx scripts/cms/seed-catalog.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/drizzle": "3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "nodemailer": "^8.0.7",
    "payload": "^3.84.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "24.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "4.0.2"
  }
}
